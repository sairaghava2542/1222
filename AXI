# ✅ AXI4 Slave – INCR4 Only

```verilog
module axi4_slave_incr4 (

    input  wire        ACLK,
    input  wire        ARESETn,

    //================ WRITE ADDRESS ==================
    input  wire [31:0] AWADDR,
    input  wire [7:0]  AWLEN,
    input  wire [2:0]  AWSIZE,
    input  wire [1:0]  AWBURST,
    input  wire        AWVALID,
    output reg         AWREADY,

    //================ WRITE DATA =====================
    input  wire [31:0] WDATA,
    input  wire        WVALID,
    input  wire        WLAST,
    output reg         WREADY,

    //================ WRITE RESPONSE =================
    output reg         BVALID,
    input  wire        BREADY,

    //================ READ ADDRESS ===================
    input  wire [31:0] ARADDR,
    input  wire [7:0]  ARLEN,
    input  wire [2:0]  ARSIZE,
    input  wire [1:0]  ARBURST,
    input  wire        ARVALID,
    output reg         ARREADY,

    //================ READ DATA ======================
    output reg [31:0]  RDATA,
    output reg         RVALID,
    output reg         RLAST,
    input  wire        RREADY
);

    //==================================================
    // Internal Memory
    //==================================================

    reg [31:0] mem [0:255];

    //==================================================
    // Write Control
    //==================================================

    reg [31:0] write_addr;
    reg [7:0]  write_len;
    reg [7:0]  write_count;

    //==================================================
    // Read Control
    //==================================================

    reg [31:0] read_addr;
    reg [7:0]  read_len;
    reg [7:0]  read_count;

    //==================================================
    // WRITE ADDRESS HANDSHAKE
    //==================================================

    always @(posedge ACLK or negedge ARESETn) begin
        if (!ARESETn)
            AWREADY <= 0;
        else
            AWREADY <= ~AWREADY && AWVALID;
    end

    // Capture write address
    always @(posedge ACLK) begin
        if (AWVALID && AWREADY) begin
            write_addr  <= AWADDR;
            write_len   <= AWLEN;
            write_count <= 0;
        end
    end

    //==================================================
    // WRITE DATA HANDSHAKE
    //==================================================

    always @(posedge ACLK or negedge ARESETn) begin
        if (!ARESETn)
            WREADY <= 0;
        else if (AWVALID && AWREADY)
            WREADY <= 1;
        else if (WLAST && WVALID && WREADY)
            WREADY <= 0;
    end

    // Write data to memory
    always @(posedge ACLK) begin
        if (WVALID && WREADY) begin
            mem[(write_addr >> 2) + write_count] <= WDATA;
            write_count <= write_count + 1;
        end
    end

    //==================================================
    // WRITE RESPONSE
    //==================================================

    always @(posedge ACLK or negedge ARESETn) begin
        if (!ARESETn)
            BVALID <= 0;
        else if (WLAST && WVALID && WREADY)
            BVALID <= 1;
        else if (BVALID && BREADY)
            BVALID <= 0;
    end

    //==================================================
    // READ ADDRESS HANDSHAKE
    //==================================================

    always @(posedge ACLK or negedge ARESETn) begin
        if (!ARESETn)
            ARREADY <= 0;
        else
            ARREADY <= ~ARREADY && ARVALID;
    end

    // Capture read address
    always @(posedge ACLK) begin
        if (ARVALID && ARREADY) begin
            read_addr  <= ARADDR;
            read_len   <= ARLEN;
            read_count <= 0;
            RVALID     <= 1;
        end
    end

    //==================================================
    // READ DATA GENERATION
    //==================================================

    always @(posedge ACLK or negedge ARESETn) begin
        if (!ARESETn) begin
            RVALID <= 0;
            RLAST  <= 0;
        end
        else if (RVALID && RREADY) begin

            RDATA <= mem[(read_addr >> 2) + read_count];

            if (read_count == read_len) begin
                RLAST <= 1;
                RVALID <= 0;
            end
            else begin
                read_count <= read_count + 1;
            end
        end
        else if (RLAST) begin
            RLAST <= 0;
        end
    end

endmodule
```

