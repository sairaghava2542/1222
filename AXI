## ✅ AXI-Lite Master Code

```verilog
module axi_lite_master (

    input  wire        ACLK,
    input  wire        ARESETn,

    // Control Signals
    input  wire        start_write,
    input  wire        start_read,
    input  wire [31:0] write_addr,
    input  wire [31:0] write_data,
    input  wire [31:0] read_addr,

    output reg  [31:0] read_data,
    output reg         done,

    //================ WRITE ADDRESS CHANNEL ================
    output reg [31:0] AWADDR,
    output reg        AWVALID,
    input  wire       AWREADY,

    //================ WRITE DATA CHANNEL ===================
    output reg [31:0] WDATA,
    output reg        WVALID,
    input  wire       WREADY,

    //================ WRITE RESPONSE CHANNEL ===============
    input  wire [1:0] BRESP,
    input  wire       BVALID,
    output reg        BREADY,

    //================ READ ADDRESS CHANNEL =================
    output reg [31:0] ARADDR,
    output reg        ARVALID,
    input  wire       ARREADY,

    //================ READ DATA CHANNEL ====================
    input  wire [31:0] RDATA,
    input  wire [1:0]  RRESP,
    input  wire        RVALID,
    output reg         RREADY
);

    //========================================================
    // FSM States
    //========================================================

    parameter IDLE        = 3'd0;
    parameter WRITE_ADDR  = 3'd1;
    parameter WRITE_RESP  = 3'd2;
    parameter READ_ADDR   = 3'd3;
    parameter READ_DATA   = 3'd4;

    reg [2:0] state;

    //========================================================
    // FSM
    //========================================================

    always @(posedge ACLK or negedge ARESETn) begin
        if (!ARESETn) begin
            state    <= IDLE;
            done     <= 0;

            AWVALID  <= 0;
            WVALID   <= 0;
            BREADY   <= 0;
            ARVALID  <= 0;
            RREADY   <= 0;
        end
        else begin
            case (state)

            //================================================
            IDLE:
            begin
                done <= 0;

                if (start_write) begin
                    AWADDR  <= write_addr;
                    WDATA   <= write_data;
                    AWVALID <= 1;
                    WVALID  <= 1;
                    state   <= WRITE_ADDR;
                end
                else if (start_read) begin
                    ARADDR  <= read_addr;
                    ARVALID <= 1;
                    state   <= READ_ADDR;
                end
            end

            //================================================
            WRITE_ADDR:
            begin
                if (AWREADY)
                    AWVALID <= 0;

                if (WREADY)
                    WVALID <= 0;

                if (AWREADY && WREADY) begin
                    BREADY <= 1;
                    state  <= WRITE_RESP;
                end
            end

            //================================================
            WRITE_RESP:
            begin
                if (BVALID) begin
                    BREADY <= 0;
                    done   <= 1;
                    state  <= IDLE;
                end
            end

            //================================================
            READ_ADDR:
            begin
                if (ARREADY) begin
                    ARVALID <= 0;
                    RREADY  <= 1;
                    state   <= READ_DATA;
                end
            end
            //================================================
            READ_DATA:
            begin
                if (RVALID) begin
                    read_data <= RDATA;
                    RREADY    <= 0;
                    done      <= 1;
                    state     <= IDLE;
                end
            end

            endcase
        end
    end
endmodule
