module producer (
    input  wire clk,
    input  wire rstn,
    input  wire ready,
    output reg  valid,
    output reg [7:0] data
);

    reg [7:0] counter;

    always @(posedge clk or negedge rstn) begin
        if (!rstn) begin
            counter <= 1;
            valid   <= 0;
            data    <= 0;
        end
        else begin
            valid <= 1;   // Always trying to send

            if (valid && ready) begin
                data <= counter;
                counter <= counter + 1;
            end
        end
    end

endmodule
