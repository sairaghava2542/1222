module axis_master (
    input  wire clk,
    input  wire rstn,
    input  wire tready,
    output reg  tvalid,
    output reg [7:0] tdata,
    output reg  tlast
);

    reg [3:0] count;

    always @(posedge clk or negedge rstn) begin
        if (!rstn) begin
            count  <= 0;
            tvalid <= 0;
            tdata  <= 0;
            tlast  <= 0;
        end
        else begin
            tvalid <= 1;  // always trying to send

            if (tvalid && tready) begin
                tdata <= count;
                count <= count + 1;

                if (count == 7)
                    tlast <= 1;
                else
                    tlast <= 0;
            end
        end
    end
endmodule
