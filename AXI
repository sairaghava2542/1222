module axi4_master_incr4 (

    input  wire        ACLK,
    input  wire        ARESETn,

    input  wire        start_write,
    input  wire        start_read,
    input  wire [31:0] base_addr,
    input  wire [31:0] write_data,

    output reg         done,

    //================ WRITE ADDRESS CHANNEL ================
    output reg [31:0]  AWADDR,
    output reg [7:0]   AWLEN,
    output reg [2:0]   AWSIZE,
    output reg [1:0]   AWBURST,
    output reg         AWVALID,
    input  wire        AWREADY,

    //================ WRITE DATA CHANNEL ===================
    output reg [31:0]  WDATA,
    output reg         WVALID,
    output reg         WLAST,
    input  wire        WREADY,

    //================ WRITE RESPONSE ========================
    input  wire        BVALID,
    output reg         BREADY,

    //================ READ ADDRESS CHANNEL =================
    output reg [31:0]  ARADDR,
    output reg [7:0]   ARLEN,
    output reg [2:0]   ARSIZE,
    output reg [1:0]   ARBURST,
    output reg         ARVALID,
    input  wire        ARREADY,

    //================ READ DATA CHANNEL ====================
    input  wire [31:0] RDATA,
    input  wire        RVALID,
    input  wire        RLAST,
    output reg         RREADY
);

    //========================================================
    // FSM States
    //========================================================

    parameter IDLE        = 3'd0;
    parameter WRITE_ADDR  = 3'd1;
    parameter WRITE_DATA  = 3'd2;
    parameter WRITE_RESP  = 3'd3;
    parameter READ_ADDR   = 3'd4;
    parameter READ_DATA   = 3'd5;

    reg [2:0] state;
    reg [2:0] beat_count;

    //========================================================
    // FSM
    //========================================================

    always @(posedge ACLK or negedge ARESETn) begin
        if (!ARESETn) begin
            state <= IDLE;
            done  <= 0;

            AWVALID <= 0;
            WVALID  <= 0;
            BREADY  <= 0;
            ARVALID <= 0;
            RREADY  <= 0;
            WLAST   <= 0;
        end
        else begin

            case (state)

            //================================================
            IDLE:
            begin
                done <= 0;
                beat_count <= 0;

                if (start_write) begin
                    AWADDR  <= base_addr;
                    AWLEN   <= 8'd3;     // 4 beats
                    AWSIZE  <= 3'd2;     // 4 bytes
                    AWBURST <= 2'b01;    // INCR
                    AWVALID <= 1;
                    state   <= WRITE_ADDR;
                end
                else if (start_read) begin
                    ARADDR  <= base_addr;
                    ARLEN   <= 8'd3;
                    ARSIZE  <= 3'd2;
                    ARBURST <= 2'b01;
                    ARVALID <= 1;
                    state   <= READ_ADDR;
                end
            end

            //================================================
            WRITE_ADDR:
            begin
                if (AWREADY) begin
                    AWVALID <= 0;
                    WVALID  <= 1;
                    state   <= WRITE_DATA;
                end
            end

            //================================================
            WRITE_DATA:
            begin
                if (WREADY) begin
                    WDATA <= write_data + beat_count;

                    if (beat_count == 3) begin
                        WLAST <= 1;
                        state <= WRITE_RESP;
                        WVALID <= 0;
                        BREADY <= 1;
                    end

                    beat_count <= beat_count + 1;
                end
            end

            //================================================
            WRITE_RESP:
            begin
                if (BVALID) begin
                    BREADY <= 0;
                    WLAST  <= 0;
                    done   <= 1;
                    state  <= IDLE;
                end
            end

            //================================================
            READ_ADDR:
            begin
                if (ARREADY) begin
                    ARVALID <= 0;
                    RREADY  <= 1;
                    state   <= READ_DATA;
                end
            end

            //================================================
            READ_DATA:
            begin
                if (RVALID) begin
                    if (RLAST) begin
                        RREADY <= 0;
                        done   <= 1;
                        state  <= IDLE;
                    end
                end
            end

            endcase
        end
    end

endmodule
