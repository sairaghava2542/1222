Add:

```verilog
reg [31:0] curr_read_addr;
reg [31:0] read_wrap_base;
reg [31:0] read_wrap_size;
```

Capture AR:

```verilog
always @(posedge ACLK) begin
    if (ARVALID && ARREADY) begin
        curr_read_addr <= ARADDR;

        read_wrap_size <= (ARLEN + 1) << ARSIZE;
        read_wrap_base <= (ARADDR / read_wrap_size) * read_wrap_size;

        read_len   <= ARLEN;
        read_count <= 0;
    end
end
```

Modify RDATA generation:

```verilog
if (RVALID && RREADY) begin

    if (read_count == read_len)
        RLAST <= 1;

    read_count <= read_count + 1;

    if (ARBURST == 2'b01) begin
        curr_read_addr <= curr_read_addr + (1 << ARSIZE);
    end
    else if (ARBURST == 2'b10) begin
        if (curr_read_addr + (1 << ARSIZE) >= read_wrap_base + read_wrap_size)
            curr_read_addr <= read_wrap_base;
        else
            curr_read_addr <= curr_read_addr + (1 << ARSIZE);
    end
end
```

